// tsconfig.main.json - Main process (CommonJS)
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    //"outDir": "./dist/main",
    "rootDir": "./src/main",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "electron"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationDir": "./src/main/types"
  },
  "include": ["src/main/**/*"]
}
