{
  "name": "intellidesk",
  "version": "2.0.4",
  "description": "An ai application powered by mistral models",
  "main": "src/main/index.js",
  "homepage": "src/assets/home.html",
  "scripts": {
    "test": "echo \"INFO: no test specified\" && exit 0",
    "tailwind:build": "NODE_ENV=production npx tailwindcss -i ./src/ui/styles/config.css -o ./src/ui/styles/global.css --minify",
    "tailwind:watch": "npx tailwindcss -i ./src/ui/styles/config.css -o ./src/ui/styles/global.css --watch",
    "preview": "vite preview",
    "dev": "concurrently \"npm:dev:*\"",
    "dev:react": "vite",
    "dev:electron": "electron .",
    "dev:types": "tsc --noEmit --watch",
    "dev:styles": "tailwindcss -i ./src/ui/styles/config.css -o ./src/ui/styles/global.css --watch",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "build": "npm run clean && npm run type-check && npm run build:all",
    "build:all": "npm-run-all build:main build:preload build:core build:react",
    "build:main": "tsc -p tsconfig.main.json",
    "build:core": "tsc -p tsconfig.core.json",
    "build:ui": "tsc -p tsconfig.ui.json",
    "build:react": "vite build",
    "package": "npm run build && npm run package:electron",
    "package:electron": "electron-builder",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "styles": "tailwindcss -i ./src/ui/styles/config.css -o ./src/ui/styles/global.css --minify"
  },
  "keywords": [],
  "author": {
    "name": "Wambua Mwikya aka Skye",
    "email": "swskye17@gmail.com"
  },
  "license": "GNU",
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "electron": "^34.1.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {
    "@eazevedociss/duckduckgo-search": "^1.0.9",
    "@fiahfy/icns": "^0.0.7",
    "@hpcc-js/wasm-graphviz": "^1.7.0",
    "@mistralai/mistralai": "^1.5.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@vitejs/plugin-react": "^5.1.0",
    "assert": "^2.1.0",
    "axios": "^1.13.4",
    "base": "^3.0.0",
    "bl": "^6.0.16",
    "braces": "^3.0.3",
    "browser": "^0.2.6",
    "browserify-fs": "^1.0.0",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "call-bound": "^1.0.3",
    "canvg": "^4.0.2",
    "child-process-promise": "^2.1.3",
    "compression-webpack-plugin": "^11.1.0",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^7.1.2",
    "cytoscape": "^3.31.2",
    "docx": "^9.5.1",
    "dompurify": "^3.2.5",
    "dotenv": "^16.4.7",
    "dotenv-expand": "^12.0.1",
    "electron-is-dev": "^3.0.1",
    "engine-base": "^1.0.0",
    "events": "^3.3.0",
    "file-saver": "^2.0.5",
    "fs": "^0.0.1-security",
    "graphlib": "^2.1.8",
    "graphlib-dot": "^0.6.4",
    "gulp-util": "^1.0.0",
    "highlight.js": "latest",
    "html-to-docx": "^1.8.0",
    "html-to-image": "^1.11.11",
    "html-to-pdf": "^0.1.11",
    "html2canvas": "^1.4.1",
    "https-browserify": "^1.0.0",
    "husky": "^9.1.7",
    "js-yaml": "^4.1.0",
    "jscharting": "^3.4.0",
    "jspdf": "^3.0.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.22",
    "keytar": "latest",
    "level": "^9.0.0",
    "levelup": "^5.1.1",
    "lightweight-charts": "^5.0.6",
    "lucide-react": "^0.563.0",
    "map-schema": "^0.3.0",
    "marked": "^15.0.3",
    "minimatch": "^10.0.1",
    "mistral": "^0.0.1",
    "mongodb": "^5.0.0",
    "motion": "^12.38.0",
    "mysql2": "^3.0.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "pg": "^8.0.0",
    "process": "^0.11.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "read-file-relative": "^1.2.0",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "set-value": "^4.1.0",
    "sharp": "^0.34.2",
    "shelljs": "^0.8.5",
    "sqlite": "^5.0.0",
    "sqlite3": "^5.0.0",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "style-loader": "^4.0.0",
    "update": "^0.7.4",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "vite": "^7.1.12",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vm-browserify": "^1.1.2"
  },
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "build/**/*",
    "src/core/**/*",
    "src/ui/**/*",
    "src/main/**/*",
    "public/**/*",
    "!node_modules/",
    "!eproj"
  ],
  "build": {
    "appId": "com.intellidesk.app",
    "productName": "IntelliDesk",
    "electronDownload": {
      "cache": true
    },
    "asar": true,
    "files": [
      "**/*"
    ],
    "asarUnpack": "**/node_modules/keytar/**",
    "extraResources": [
      {
        "from": "src/assets/",
        "to": "assets/"
      },
      {
        "from": "build/",
        "to": "build/",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "node_modules/keytar",
        "to": "app.asar.unpacked/node_modules/keytar"
      }
    ],
    "mac": {
      "icon": "src/assets/intellidesk.icns",
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.dmg"
    },
    "win": {
      "icon": "src/assets/intellidesk.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowToChangeInstallationDirectory": true,
      "license": "LICENSE",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-portable-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "armv7l",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "snap",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "src/icons",
      "maintainer": "Skye <swskye17@gmail.com>",
      "synopsis": "IntelliDesk Desktop",
      "description": "AI for all tasks, chat, ocr, image-generation, document analysis ..."
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.AppImage"
    },
    "deb": {
      "priority": "optional",
      "depends": [
        "libappindicator1",
        "libnotify-bin",
        "libsecret-1-dev"
      ],
      "artifactName": "${productName}_${version}_${arch}.deb"
    },
    "snap": {
      "summary": "IntelliDesk Snap Package",
      "grade": "stable",
      "confinement": "classic",
      "plugs": [
        "network",
        "home",
        "audio-playback"
      ],
      "artifactName": "${productName}_${version}_${arch}.snap"
    }
  }
}
