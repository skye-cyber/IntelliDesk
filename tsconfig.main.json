// tsconfig.main.json - Main process (CommonJS)
{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    //"outDir": "./dist/main",
    "rootDir": "./src/main",
    "lib": ["es2021", "DOM"],
    "types": ["node", "electron"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "noUnusedLocals": false,
    "declarationDir": "./src/main/types"
  },
  "include": ["src/main/**/*"],
  "exclude": ["src/main/types/**/*", "DatabaseManager.ts"]
}
